<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>{{ report_name }} — {{ generated_day }}</title>
{% from "_report_sections.html.j2" import render_sections %}
<style>
  :root {
    --ink: #1a1a1a;
    --ink-soft: #4a4a4a;
    --ink-faint: #7a7a72;
    --paper: #fbfaf7;
    --rule: #ddd9d0;
    --rule-ink: #1a1a1a;
    --note-bg: #f4f1ea;
    --warn-bg: #f9f2e7;
    --warn-border: #d9c6a0;
  }
  * { box-sizing: border-box; }
  html { font-size: 17px; }
  body {
    margin: 0;
    background: var(--paper);
    color: var(--ink);
    font-family: Georgia, "Times New Roman", Times, serif;
    line-height: 1.5;
    -webkit-font-smoothing: antialiased;
  }
  .sheet { max-width: 46rem; margin: 0 auto; padding: 2.6rem 1.4rem 4rem; }

  .smallcaps {
    text-transform: uppercase;
    letter-spacing: 0.14em;
    font-size: 0.72rem;
    color: var(--ink-soft);
  }

  /* Masthead */
  .masthead {
    text-align: center;
    border-bottom: 4px double var(--rule-ink);
    padding-bottom: 1.3rem;
    margin-bottom: 1.1rem;
  }
  .masthead h1 {
    margin: 0 0 0.35rem;
    font-size: 2.5rem;
    font-weight: 700;
    letter-spacing: 0.01em;
  }
  .masthead .dateline { margin: 0 0 0.3rem; }
  .masthead .counts { margin: 0; font-size: 0.85rem; color: var(--ink-faint); font-style: italic; }

  /* Sections */
  section.query { margin: 0 0 2.6rem; }
  section.query > header {
    border-top: 1px solid var(--rule-ink);
    padding-top: 0.85rem;
    margin-bottom: 1.1rem;
  }
  section.query h2 {
    margin: 0;
    font-size: 1.55rem;
    font-weight: 700;
    line-height: 1.25;
  }
  section.query h2 .count {
    font-size: 0.95rem;
    font-weight: 400;
    font-style: italic;
    color: var(--ink-faint);
    white-space: nowrap;
  }
  .query-meta { margin: 0.3rem 0 0; font-size: 0.8rem; color: var(--ink-faint); }
  .depth-note {
    margin: 0.55rem 0 0;
    padding: 0.45rem 0.7rem;
    background: var(--note-bg);
    border-left: 2px solid var(--rule);
    font-size: 0.8rem;
    font-style: italic;
    color: var(--ink-faint);
  }

  /* Articles */
  article.entry { padding: 0.95rem 0; border-bottom: 1px solid var(--rule); }
  article.entry:last-child { border-bottom: none; }
  .headline { margin: 0 0 0.3rem; font-size: 1.14rem; font-weight: 700; line-height: 1.32; }
  .headline a { color: inherit; text-decoration: none; }
  .headline a:hover { text-decoration: underline; text-underline-offset: 3px; }
  .meta { margin: 0 0 0.35rem; }
  .meta .outlet { color: var(--ink); font-weight: 700; }
  .standfirst { margin: 0; font-size: 0.94rem; color: var(--ink-soft); line-height: 1.55; }

  .empty { font-style: italic; color: var(--ink-faint); margin: 0.4rem 0 0; }

  footer.colophon {
    margin-top: 3rem;
    padding-top: 1rem;
    border-top: 4px double var(--rule-ink);
    text-align: center;
    font-size: 0.8rem;
    font-style: italic;
    color: var(--ink-faint);
  }

  /* Print: made to sit on a morning-meeting table */
  @media print {
    html { font-size: 10.5pt; }
    body { background: #fff; color: #000; }
    .sheet { max-width: none; padding: 0; }
    article.entry { break-inside: avoid; }
    section.query > header { break-after: avoid; }
    .headline a { text-decoration: none; color: #000; }
    @page { margin: 2cm; }
  }
</style>
</head>
<body>
<div class="sheet">

  <header class="masthead">
    <h1>{{ report_name }}</h1>
    <p class="dateline smallcaps">Generated {{ generated_day }} at {{ generated_at.strftime("%H:%M") }}</p>
    <p class="counts">{{ publications }} publication{{ "s" if publications != 1 }} · {{ total_articles }} result{{ "s" if total_articles != 1 }}</p>
  </header>

  {{ render_sections(sections) }}

  <footer class="colophon">
    <p>Generated locally from publisher RSS feeds. Headlines link to the publisher’s own site.</p>
  </footer>

</div>
</body>
</html>
