<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>{% block title %}Mimi — the media monitoring tool{% endblock %}</title>
<style>
  :root {
    --ink: #1a1a1a; --ink-soft: #4a4a4a; --ink-faint: #7a7a72;
    --paper: #fbfaf7; --field: #ffffff; --rule: #ddd9d0; --rule-ink: #1a1a1a;
    --accent: #1a1a1a; --error-bg: #f7e9e6; --error-border: #c9a59c; --error-ink: #7a2e22;
    --ok-bg: #eaf1e8; --ok-border: #a9c3a0; --note-bg: #f4f1ea; --card-bg: #fdfcfa;
    --warn-bg: #f9f2e7; --warn-border: #d9c6a0;
  }
  * { box-sizing: border-box; }
  html { font-size: 17px; }
  body { margin: 0; background: var(--paper); color: var(--ink);
    font-family: Georgia, "Times New Roman", Times, serif; line-height: 1.5;
    -webkit-font-smoothing: antialiased; }
  .sheet { max-width: 44rem; margin: 0 auto; padding: 2.4rem 1.4rem 4rem; }
  .smallcaps { text-transform: uppercase; letter-spacing: 0.13em; font-size: 0.72rem; color: var(--ink-soft); }

  header.masthead { text-align: center; border-bottom: 4px double var(--rule-ink);
    padding-bottom: 1.1rem; margin-bottom: 0; }
  header.masthead h1 { margin: 0 0 0.3rem; font-size: 2.3rem; font-weight: 700; }
  header.masthead p { margin: 0; font-style: italic; color: var(--ink-faint); }

  /* Newspaper-style section nav: shared across the editor and report views. */
  .section-nav { display: flex; flex-wrap: wrap; align-items: center; gap: 0.3rem 1.25rem;
    padding: 0.45rem 0; border-bottom: 1px solid var(--rule); margin-bottom: 1.7rem; }
  .new-report-btn { font-family: Georgia, serif; font-size: 0.72rem; text-transform: uppercase;
    letter-spacing: 0.1em; font-weight: 700; color: var(--paper); background: var(--accent);
    padding: 0.45em 0.9em; border-radius: 3px; text-decoration: none; white-space: nowrap; }
  .new-report-btn:hover { background: #000; }

  /* "I'm feeling lucky": styled like the Info button at rest; hovering
     lights a row of little CSS flames along its top edge — the one
     deliberate splash of colour in the whole monochrome paper. */
  .lucky-form { margin: 0; }
  .lucky-btn { position: relative; font-family: Georgia, serif; font-size: 0.72rem;
    text-transform: uppercase; letter-spacing: 0.1em; font-weight: 700; color: var(--ink);
    background: none; border: 1px solid var(--rule-ink); padding: 0.4em 0.85em;
    border-radius: 3px; cursor: pointer; white-space: nowrap; }
  .lucky-btn:hover, .lucky-btn:focus-visible { color: #7a2e22; border-color: #b3401f;
    background: #fdf3ea; }
  .lucky-btn::before, .lucky-btn::after { content: ""; position: absolute; left: 5%;
    right: 5%; pointer-events: none; opacity: 0; transform-origin: 50% 100%;
    transition: opacity 0.25s; }
  /* Outer flames: taller orange tongues. */
  .lucky-btn::before { top: -0.62rem; height: 0.72rem; background:
    radial-gradient(ellipse 11% 95% at 8% 100%,  #e25822 0%, rgba(226,88,34,0) 72%),
    radial-gradient(ellipse 13% 80% at 24% 100%, #f2a71b 0%, rgba(242,167,27,0) 74%),
    radial-gradient(ellipse 11% 100% at 41% 100%, #e25822 0%, rgba(226,88,34,0) 72%),
    radial-gradient(ellipse 13% 85% at 59% 100%, #f2a71b 0%, rgba(242,167,27,0) 74%),
    radial-gradient(ellipse 11% 95% at 76% 100%, #e25822 0%, rgba(226,88,34,0) 72%),
    radial-gradient(ellipse 12% 82% at 92% 100%, #f2a71b 0%, rgba(242,167,27,0) 74%); }
  /* Inner flames: shorter, brighter core. */
  .lucky-btn::after { top: -0.4rem; height: 0.5rem; filter: blur(0.5px); background:
    radial-gradient(ellipse 9% 90% at 15% 100%, #ffd23f 0%, rgba(255,210,63,0) 70%),
    radial-gradient(ellipse 9% 95% at 50% 100%, #ffd23f 0%, rgba(255,210,63,0) 70%),
    radial-gradient(ellipse 9% 90% at 84% 100%, #ffd23f 0%, rgba(255,210,63,0) 70%); }
  .lucky-btn:hover::before, .lucky-btn:focus-visible::before { opacity: 1;
    animation: flame-flicker 0.34s ease-in-out infinite alternate; }
  .lucky-btn:hover::after, .lucky-btn:focus-visible::after { opacity: 0.9;
    animation: flame-flicker 0.27s ease-in-out infinite alternate-reverse; }
  @keyframes flame-flicker {
    from { transform: scaleY(0.82) scaleX(0.98) translateY(1px); filter: brightness(0.95); }
    to   { transform: scaleY(1.14) scaleX(1.03) translateY(-1.5px); filter: brightness(1.12); }
  }
  @media (prefers-reduced-motion: reduce) {
    .lucky-btn:hover::before, .lucky-btn:focus-visible::before,
    .lucky-btn:hover::after, .lucky-btn:focus-visible::after { animation: none; }
  }

  .nav-empty { font-style: italic; font-size: 0.8rem; color: var(--ink-faint); }

  /* Saved-search menu: one control that opens a scrollable index panel, so the
     nav stays a single fixed-height row however many searches exist — which also
     keeps the report view's widget-positioning JS (measured off the nav's
     bottom) correct no matter the count. */
  .nav-menu { position: relative; }
  .nav-menu > .nav-menu-label { display: inline-block; font-family: Georgia, serif;
    text-transform: uppercase; letter-spacing: 0.09em; font-size: 0.75rem; color: var(--ink);
    padding: 0.35rem 0.1rem; cursor: default; border-bottom: 2px solid transparent; }
  .nav-menu:hover > .nav-menu-label, .nav-menu:focus-within > .nav-menu-label {
    border-bottom-color: var(--rule-ink); }
  .nav-count { color: var(--ink-faint); }
  .nav-menu-panel { position: absolute; top: 100%; left: 0; z-index: 20; min-width: 20rem;
    background: var(--field); border: 1px solid var(--rule); border-radius: 3px;
    box-shadow: 0 4px 14px rgba(0,0,0,0.09); display: none; }
  .nav-menu:hover > .nav-menu-panel, .nav-menu:focus-within > .nav-menu-panel { display: block; }
  .nav-menu-scroll { max-height: min(60vh, 26rem); overflow-y: auto; padding: 0.15rem 0; }
  .nav-row { display: flex; align-items: baseline; justify-content: space-between; gap: 1rem;
    padding: 0.4rem 0.9rem; border-bottom: 1px solid var(--rule); }
  .nav-row:last-child { border-bottom: none; }
  .nav-row-name-form { margin: 0; flex: 1; min-width: 0; }
  .nav-row-name { display: block; width: 100%; text-align: left; font-family: Georgia, serif;
    text-transform: uppercase; letter-spacing: 0.08em; font-size: 0.8rem; color: var(--ink);
    background: none; border: none; cursor: pointer; padding: 0; }
  .nav-row-name:hover { text-decoration: underline; text-underline-offset: 2px; }
  .nav-row-actions { display: flex; gap: 0.7rem; white-space: nowrap; }
  .nav-row-actions form { margin: 0; }
  .nav-row-actions button { font-family: Georgia, serif; font-size: 0.72rem; text-transform: uppercase;
    letter-spacing: 0.08em; color: var(--ink-faint); background: none; border: none; cursor: pointer; padding: 0; }
  .nav-row:hover .nav-row-actions button, .nav-row:focus-within .nav-row-actions button { color: var(--ink-soft); }
  .nav-row-actions button:hover { color: var(--ink); text-decoration: underline; }

  /* Info button + modal */
  .info-btn { font-family: Georgia, serif; font-size: 0.72rem; text-transform: uppercase;
    letter-spacing: 0.1em; font-weight: 700; color: var(--ink); background: none;
    border: 1px solid var(--rule-ink); padding: 0.4em 0.85em; border-radius: 3px; cursor: pointer; white-space: nowrap; }
  .info-btn:hover { background: var(--note-bg); }
  #info-modal { display: none; position: fixed; inset: 0; z-index: 30; background: rgba(26,26,26,0.42);
    padding: 2rem 1rem; overflow-y: auto; }
  #info-modal.open { display: flex; align-items: flex-start; justify-content: center; }
  .info-panel { background: var(--paper); max-width: 40rem; width: 100%; margin: auto; border-radius: 5px;
    box-shadow: 0 12px 44px rgba(0,0,0,0.28); padding: 1.5rem 1.6rem 1.8rem; }
  .info-head { display: flex; align-items: baseline; justify-content: space-between;
    border-bottom: 2px solid var(--rule-ink); padding-bottom: 0.6rem; margin-bottom: 1.2rem; }
  .info-head h2 { margin: 0; font-size: 1.5rem; }
  .info-close { font-family: Georgia, serif; font-size: 1.7rem; line-height: 1; color: var(--ink-soft);
    background: none; border: none; cursor: pointer; padding: 0 0.2rem; }
  .info-close:hover { color: var(--ink); }
  .info-box { background: var(--note-bg); border-radius: 3px; padding: 0.9rem 1.15rem; margin-bottom: 1.1rem; }
  .info-box:last-child { margin-bottom: 0; }
  .info-box h3 { margin: 0 0 0.5rem; font-size: 1.02rem; }
  .info-box ul { margin: 0; padding-left: 1.1rem; }
  .info-box li, .info-box p { font-size: 0.85rem; color: var(--ink-soft); line-height: 1.55; margin: 0.35rem 0; }
  .info-box p:first-child { margin-top: 0; }
  .info-box p:last-child { margin-bottom: 0; }
  .info-box strong { color: var(--ink); }
  .info-box code { font-style: normal; font-size: 0.8rem; }

  /* Toast: transient save confirmation, bottom-right. */
  .toast { position: fixed; bottom: 1.3rem; right: 1.3rem; z-index: 40; max-width: 24rem;
    background: var(--ok-bg); border: 1px solid var(--ok-border); color: #2f5227;
    padding: 0.8rem 1.1rem; border-radius: 4px; font-size: 0.9rem; line-height: 1.45;
    box-shadow: 0 8px 24px rgba(0,0,0,0.16); }
  @media (max-width: 34rem) { .toast { left: 1.3rem; right: 1.3rem; max-width: none; } }

  {% block extra_css %}{% endblock %}
</style>
</head>
<body>
<div class="sheet">

  <header class="masthead">
    <h1>Mimi, the media monitoring tool</h1>
    <p>An open-source project for building reports on US and UK headlines.</p>
    <p>Developed by Ziad Ramley.</p>
  </header>

  <nav class="section-nav">
    <button type="button" class="info-btn" onclick="openInfo()">Info</button>
    <a class="new-report-btn" href="/?new=1" onclick="return confirmNew();">New search</a>
    {% if lucky %}
    <form class="lucky-form" method="post" action="/lucky">
      <input type="hidden" name="csrf" value="{{ csrf }}">
      <button type="submit" class="lucky-btn" title="Roll a random search and run it">I’m feeling lucky</button>
    </form>
    {% endif %}
    {#- All saved searches collapse behind ONE menu, so the nav stays a single
        row however many exist. The panel scrolls internally; each row's name is
        the Edit trigger (click to open it in the editor), with Run and Delete
        alongside. All three change state, so all are POST forms with the CSRF
        token. -#}
    {% if saved_searches %}
    <div class="nav-menu" tabindex="0" aria-haspopup="true">
      <span class="nav-menu-label">Saved searches <span class="nav-count">({{ saved_searches|length }})</span> &#9662;</span>
      <div class="nav-menu-panel" role="menu">
        <div class="nav-menu-scroll">
          {% for s in saved_searches %}
          <div class="nav-row">
            <form class="nav-row-name-form" method="post" action="/edit/{{ s.slug }}">
              <input type="hidden" name="csrf" value="{{ csrf }}">
              <button type="submit" class="nav-row-name" title="Edit “{{ s.name }}”">{{ s.name }}</button>
            </form>
            <span class="nav-row-actions">
              <form method="post" action="/run/{{ s.slug }}">
                <input type="hidden" name="csrf" value="{{ csrf }}">
                <button type="submit">Run</button>
              </form>
              <form class="delete-form" method="post" action="/delete/{{ s.slug }}" data-name="{{ s.name }}">
                <input type="hidden" name="csrf" value="{{ csrf }}">
                <button type="submit">Delete</button>
              </form>
            </span>
          </div>
          {% endfor %}
        </div>
      </div>
    </div>
    {% else %}<span class="nav-empty">Saved searches will appear here.</span>{% endif %}
  </nav>

  {% block content %}{% endblock %}

</div>

{% if flash %}<div class="toast" id="toast">{{ flash }}</div>{% endif %}

<div id="info-modal" role="dialog" aria-modal="true" aria-labelledby="info-title">
  <div class="info-panel">
    <div class="info-head">
      <h2 id="info-title">About Mimi</h2>
      <button type="button" class="info-close" onclick="closeInfo()" aria-label="Close">&times;</button>
    </div>

    <div class="info-box">
      <h3>How to use Mimi</h3>
      <ul>
        <li><strong>How it works:</strong> Mimi pulls headlines via RSS from a network of US and UK news outlets.</li>
        <li><strong>Queries and searches:</strong> A query is one set of parameters — keywords, a timeframe, and outlets. A search is a named combination of queries you can save and run again.</li>
        <li><strong>Reports:</strong> Generating runs your search and produces a report — a snapshot of matching headlines at that date and time. Remove any irrelevant articles, then use the printable version.</li>
      </ul>
    </div>

    <div class="info-box">
      <h3>Terms of use</h3>
      <p>Mimi is free, open-source software provided under the MIT License, “as is” and without warranty of any kind.</p>
      <p>Mimi collects only what outlets publish in their public RSS feeds — headlines, summaries, bylines, timestamps, and links. That content belongs to the publishers and remains subject to each publisher’s own terms. Mimi does not access or store full article text; read full articles through your own subscriptions.</p>
      <p>You are responsible for using Mimi in line with the terms of the outlets you monitor, and for how you use the reports it produces.</p>
    </div>

    <div class="info-box">
      <h3>Privacy policy</h3>
      <p>Mimi runs entirely on your own machine. There is no account, no server, and no analytics or tracking.</p>
      <p>The only network requests Mimi makes are to fetch the public RSS feeds you have chosen, directly from the publishers. Nothing you type — your queries, report names, or saved reports — is ever sent anywhere.</p>
      <p>Saved searches and generated reports are stored as ordinary files on your computer, in the <code>searches/</code> and <code>reports/</code> folders. They stay there until you delete them.</p>
    </div>
  </div>
</div>

{% block overlay %}{% endblock %}

<script>
  // Info modal (how-to, terms, privacy).
  function openInfo() { document.getElementById("info-modal").classList.add("open"); }
  function closeInfo() { document.getElementById("info-modal").classList.remove("open"); }
  document.getElementById("info-modal").addEventListener("click", function (e) {
    if (e.target === this) closeInfo();  // click on the backdrop closes
  });
  document.addEventListener("keydown", function (e) {
    if (e.key !== "Escape") return;
    closeInfo();
    // Close the saved-search menu too: it opens via :focus-within, so blurring
    // the focused element inside it lets it collapse.
    var active = document.activeElement;
    if (active && active.closest && active.closest(".nav-menu")) active.blur();
  });

  // "New search" confirmation.
  function confirmNew() {
    return confirm("Clear everything and start a new search? Anything you haven’t saved will be lost.");
  }

  // "I'm feeling lucky": reuse the editor's loading overlay when the page
  // has one (the report view doesn't — there the browser just navigates).
  var luckyForm = document.querySelector(".lucky-form");
  if (luckyForm) {
    luckyForm.addEventListener("submit", function () {
      var overlay = document.getElementById("overlay");
      if (overlay) overlay.style.display = "flex";
    });
  }

  // Confirm deletes. The name is read from a data- attribute (a safe HTML
  // attribute context) rather than interpolated into inline JS — so a saved
  // search named with quotes or script can't execute here.
  document.querySelectorAll(".delete-form").forEach(function (form) {
    form.addEventListener("submit", function (e) {
      var name = form.dataset.name || "this search";
      if (!confirm("Delete the saved search “" + name + "”?")) e.preventDefault();
    });
  });

  // Auto-dismiss the save-confirmation toast after 5 seconds.
  var toast = document.getElementById("toast");
  if (toast) {
    setTimeout(function () {
      toast.style.transition = "opacity 0.6s";
      toast.style.opacity = "0";
      setTimeout(function () { toast.remove(); }, 600);
    }, 5000);
  }
</script>
{% block extra_js %}{% endblock %}
</body>
</html>
