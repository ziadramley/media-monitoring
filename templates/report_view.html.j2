{% extends "_shell.html.j2" %}
{% from "_report_sections.html.j2" import render_sections %}
{% block title %}Mimi — {{ report_name }}{% endblock %}

{% block extra_css %}
  /* Report header */
  .report-head { margin-bottom: 1.6rem; }
  .report-head h1 { margin: 0 0 0.35rem; font-size: 2rem; font-weight: 700; line-height: 1.15; }
  .report-head .report-meta { margin: 0; font-size: 0.8rem; color: var(--ink-faint); font-style: italic; }
  .report-actions { margin: 0.9rem 0 0; display: flex; gap: 0.6rem; flex-wrap: wrap; }
  .report-actions a, .report-actions button { font-family: Georgia, serif; font-size: 0.72rem;
    text-transform: uppercase; letter-spacing: 0.1em; color: var(--ink-soft); background: none;
    border: 1px solid var(--rule); border-radius: 2px; padding: 0.45em 0.9em; cursor: pointer; text-decoration: none; }
  .report-actions a:hover, .report-actions button:hover { border-color: var(--ink-soft); color: var(--ink); }

  /* Sections + articles (screen twin of the portable file's styles) */
  section.query { margin: 0 0 2.6rem; }
  section.query > header { border-top: 1px solid var(--rule-ink); padding-top: 0.85rem; margin-bottom: 1.1rem; }
  section.query h2 { margin: 0; font-size: 1.5rem; font-weight: 700; line-height: 1.25; }
  section.query h2 .count { font-size: 0.92rem; font-weight: 400; font-style: italic; color: var(--ink-faint); white-space: nowrap; }
  .query-meta { margin: 0.3rem 0 0; font-size: 0.8rem; color: var(--ink-faint); }
  .depth-note { margin: 0.55rem 0 0; padding: 0.45rem 0.7rem; background: var(--note-bg);
    border-left: 2px solid var(--rule); font-size: 0.8rem; font-style: italic; color: var(--ink-faint); }
  article.entry { padding: 0.95rem 0; border-bottom: 1px solid var(--rule); }
  article.entry:last-child { border-bottom: none; }
  .headline { margin: 0 0 0.3rem; font-size: 1.12rem; font-weight: 700; line-height: 1.32; }
  .headline a { color: inherit; text-decoration: none; }
  .headline a:hover { text-decoration: underline; text-underline-offset: 3px; }
  .meta { margin: 0 0 0.35rem; }
  .meta .outlet { color: var(--ink); font-weight: 700; }
  .standfirst { margin: 0; font-size: 0.94rem; color: var(--ink-soft); line-height: 1.55; }
  .empty { font-style: italic; color: var(--ink-faint); margin: 0.4rem 0 0; }

  /* Per-article Remove (in-app only; never appears in the printable file) */
  .remove-article { display: inline; margin-left: 0.55em; }
  .remove-article button { font-family: Georgia, serif; font-size: 0.68rem; text-transform: uppercase;
    letter-spacing: 0.08em; color: var(--ink-faint); background: none; border: none; cursor: pointer;
    text-decoration: underline; padding: 0; }
  .remove-article button:hover { color: var(--error-ink); }

  /* Right-side widgets: inline at the top on narrow screens, floated into
     the right margin beside the centred column on wide screens. */
  .report-widgets { margin: 0 0 2rem; display: flex; flex-direction: column; gap: 1rem; }
  .widget { border: 1px solid var(--rule); border-radius: 4px; background: var(--card-bg); padding: 0.8rem 1rem; }
  .widget h3 { margin: 0 0 0.6rem; font-size: 0.72rem; text-transform: uppercase; letter-spacing: 0.1em;
    color: var(--ink-soft); }
  .widget.jump ol { margin: 0; padding: 0; list-style: none; counter-reset: jump; }
  .widget.jump li { margin: 0.25rem 0; }
  .widget.jump a { color: var(--ink); text-decoration: none; font-size: 0.9rem; }
  .widget.jump a:hover { text-decoration: underline; }
  .widget.jump .n { color: var(--ink-faint); font-size: 0.82rem; }
  .widget.errors { background: var(--warn-bg); border-color: var(--warn-border); }
  .widget.errors ul { margin: 0; padding-left: 1.1rem; }
  .widget.errors li { font-size: 0.82rem; color: var(--ink-soft); margin: 0.2rem 0; }
  .widget.errors code { font-size: 0.76rem; word-break: break-all; }

  @media (min-width: 78rem) {
    /* `top`/`max-height` are set precisely by JS to line the top widget up
       with the rule under the action bar; these are just pre-script fallbacks. */
    .report-widgets { position: fixed; top: 9rem; left: calc(50% + 23rem); width: 13.5rem;
      margin: 0; max-height: calc(100vh - 10rem); overflow-y: auto; }
  }
{% endblock %}

{% block content %}
  <div class="report-head">
    <h1>{{ report_name }}</h1>
    <p class="report-meta">Generated {{ generated_day }} at {{ generated_at.strftime("%H:%M") }} · {{ publications }} publication{{ "s" if publications != 1 }} · {{ total_articles }} result{{ "s" if total_articles != 1 }}</p>
    <div class="report-actions">
      <a href="/reports/{{ report_file }}" target="_blank" rel="noopener">Printable version</a>
    </div>
  </div>

  <aside class="report-widgets">
    {% if sections|length > 1 %}
    <div class="widget jump">
      <h3>Jump to</h3>
      <ol>
        {% for section in sections %}
        <li><a href="#{{ section.anchor }}">{{ section.name }} <span class="n">({{ section.articles|length }})</span></a></li>
        {% endfor %}
      </ol>
    </div>
    {% endif %}

    {% if failed_feeds %}
    <div class="widget errors">
      <h3>{{ failed_feeds|length }} feed{{ "s" if failed_feeds|length != 1 }} not reached</h3>
      <ul>
        {% for f in failed_feeds %}
        <li>{{ f.publication_name }} — <code>{{ f.feed_url }}</code> ({{ f.error }})</li>
        {% endfor %}
      </ul>
    </div>
    {% endif %}

    {% if stale_feeds %}
    <div class="widget errors">
      <h3>{{ stale_feeds|length }} feed{{ "s" if stale_feeds|length != 1 }} may be frozen</h3>
      <ul>
        {% for f in stale_feeds %}
        <li>{{ f.publication_name }} — <code>{{ f.feed_url }}</code> (newest item is {{ (f.newest_age_hours / 24)|round|int }} days old; the feed may be abandoned — consider replacing it in publications.yaml)</li>
        {% endfor %}
      </ul>
    </div>
    {% endif %}
  </aside>

  {{ render_sections(sections, removable=true, csrf=csrf) }}
{% endblock %}

{% block extra_js %}
<script>
  // Align the top of the floated widgets with the rule under the action bar.
  // Only when they're floated (wide screens); on narrow screens they sit
  // inline and these overrides are cleared.
  function positionWidgets() {
    var widgets = document.querySelector(".report-widgets");
    var nav = document.querySelector(".section-nav");
    if (!widgets || !nav) return;
    if (window.matchMedia("(min-width: 78rem)").matches) {
      var top = Math.round(nav.getBoundingClientRect().bottom + window.scrollY);
      widgets.style.top = top + "px";
      widgets.style.maxHeight = "calc(100vh - " + (top + 24) + "px)";
    } else {
      widgets.style.top = "";
      widgets.style.maxHeight = "";
    }
  }
  window.addEventListener("resize", positionWidgets);
  positionWidgets();
</script>
{% endblock %}
