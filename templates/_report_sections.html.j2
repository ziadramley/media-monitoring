{#- Shared article/section markup used by both the portable report file
    (report.html.j2) and the in-app report view (report_view.html.j2), so
    the two surfaces can never drift. Requires a `datefmt` Jinja filter and
    `.query`/`.entry`/`.headline`/`.meta`/`.standfirst` styles in the host.
    With removable=true (in-app only), each article gets a small Remove
    form so the user can prune it from the report before printing. -#}
{%- macro render_sections(sections, removable=false) -%}
{% for section in sections %}
<section class="query" id="{{ section.anchor }}">
  <header>
    <h2>{{ section.name }}
      <span class="count">— {{ section.articles|length }} match{{ "es" if section.articles|length != 1 }}, {{ section.range_label }}</span>
    </h2>
    <p class="query-meta">
      Keywords ({{ section.match }}):
      {%- for k in section.keywords %} “{{ k }}”{% if not loop.last %},{% endif %}{% endfor %}
    </p>
    {% if section.show_depth_note %}
    <p class="depth-note">RSS feeds hold a limited number of recent items and their depth varies by outlet — over a {{ section.range_label }} window, older articles may be missing from busier feeds.</p>
    {% endif %}
  </header>

  {% if section.articles %}
    {% for a in section.articles %}
    <article class="entry">
      <h3 class="headline"><a href="{{ a.url }}" target="_blank" rel="noopener">{{ a.title }}</a></h3>
      {#- a <div>, not a <p>: HTML parsers auto-close a <p> when a <form>
          starts, which would hoist the Remove form out of the line -#}
      <div class="meta smallcaps">
        <span class="outlet">{{ a.publication_name }}</span>
        {%- if a.author %} · {{ a.author }}{% endif %}
        · <time>{{ a.published|datefmt }}</time>
        {%- if removable %}
        <form class="remove-article" method="post" action="/report/remove">
          <input type="hidden" name="anchor" value="{{ section.anchor }}">
          <input type="hidden" name="key" value="{{ a.dedupe_key }}">
          <button type="submit" title="Remove this article from the report">Remove</button>
        </form>
        {%- endif %}
      </div>
      {% if a.standfirst %}<p class="standfirst">{{ a.standfirst }}</p>{% endif %}
    </article>
    {% endfor %}
  {% else %}
    <p class="empty">No matching articles found.</p>
  {% endif %}
</section>
{% endfor %}
{%- endmacro -%}
